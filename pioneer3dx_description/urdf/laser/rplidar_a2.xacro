<?xml version="1.0"?>
<robot xmlns:xacro="http://ros.org/wiki/xacro">

<xacro:macro name="rplidar_a2"
  params="name parent xyz rpy scan:=scan robot_namespace:='/' gpu:=false">

  <!-- Joint -->
  <joint name="${parent}_${name}_joint" type="fixed">
    <origin xyz="${xyz}" rpy="${rpy}" />
    <parent link="${parent}" />
    <child link="${name}_link" />
  </joint>

  <!-- Base link -->
  <link name="${name}_link">

    <!-- VISUAL (use mesh aqui se quiser) -->
    <visual>
      <origin xyz="0 0 0.02" rpy="0 0 0"/>
      <geometry>
        <!-- versão leve -->
        <cylinder radius="0.038" length="0.041"/>
        
        <!-- versão com mesh -->
        <!--
        <mesh filename="package://seu_pacote/meshes/rplidar_a2.stl"
              scale="0.001 0.001 0.001"/>
        -->
      </geometry>
      <material name="black">
        <color rgba="0.1 0.1 0.1 1"/>
      </material>
    </visual>

    <!-- COLLISION -->
    <collision>
      <origin xyz="0 0 0.02"/>
      <geometry>
        <cylinder radius="0.038" length="0.041"/>
      </geometry>
    </collision>

    <!-- INERTIAL -->
    <inertial>
      <mass value="0.2"/>
      <origin xyz="0 0 0.02"/>
      <inertia ixx="0.0001" iyy="0.0001" izz="0.0001"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>

  </link>

  <!-- FRAME DO LASER -->
  <link name="${name}_frame"/>

  <joint name="${name}_frame_joint" type="fixed">
    <parent link="${name}_link"/>
    <child link="${name}_frame"/>
    <origin xyz="0 0 0.041" rpy="0 0 0"/>
  </joint>

  <!-- SENSOR -->
  <gazebo reference="${name}_link">

    <sensor name="${name}" type="${gpu ? 'gpu_lidar' : 'lidar'}">

      <xacro:if value="${robot_namespace == '/'}">
        <topic>${scan}</topic>
        <gz_frame_id>${name}_frame</gz_frame_id>
      </xacro:if>

      <xacro:unless value="${robot_namespace == '/'}">
        <topic>${robot_namespace}/${scan}</topic>
        <gz_frame_id>${robot_namespace}/${name}_frame</gz_frame_id>
      </xacro:unless>

      <update_rate>10</update_rate>

      <lidar>
        <scan>
          <horizontal>
            <samples>720</samples>
            <resolution>1</resolution>
            <min_angle>-3.14159</min_angle>
            <max_angle>3.14159</max_angle>
          </horizontal>
        </scan>

        <range>
          <min>0.15</min>
          <max>12.0</max>
          <resolution>0.01</resolution>
        </range>

        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.01</stddev>
        </noise>

      </lidar>

      <always_on>true</always_on>
      <visualize>true</visualize>

    </sensor>
  </gazebo>

</xacro:macro>

</robot>